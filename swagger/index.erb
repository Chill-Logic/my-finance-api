<!-- HTML for static distribution bundle build -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Finance API Docs</title>
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,700|Source+Code+Pro:300,600|Titillium+Web:400,600,700" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="./swagger-ui.css" >
  <link rel="icon" type="image/png" href="/api-docs/logo-icon" />
  <style>
    html {
      box-sizing: border-box;
      overflow: -moz-scrollbars-vertical;
      overflow-y: scroll;
    }
    *,
    *:before,
    *:after {
      box-sizing: inherit;
    }
    body {
      margin: 0;
      background: #e3e1df;
    }
    /* ── Identidade visual My Finance ── */
    .mf-header {
      display: flex;
      align-items: center;
      gap: 14px;
      background: #052131;
      padding: 12px 22px;
    }
    .mf-header img { height: 34px; width: auto; }
    .mf-header .mf-header-title {
      color: #e3e1df;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 15px;
      font-weight: bold;
      letter-spacing: 0.3px;
    }
    .mf-header .mf-header-actions {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .mf-header .mf-logout {
      color: #e3e1df;
      text-decoration: none;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 13px;
      border: 1px solid rgba(227, 225, 223, 0.4);
      border-radius: 8px;
      padding: 6px 14px;
    }
    .mf-header .mf-logout:hover { background: rgba(227, 225, 223, 0.12); }
    /* Botão Authorize movido pra navbar (abre o mesmo modal do swagger-ui). */
    .mf-header .mf-authorize {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: #88a15e;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 7px 14px;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
    }
    .mf-header .mf-authorize:hover { background: #78904f; }
    .mf-header .mf-authorize svg { width: 14px; height: 14px; fill: #fff; }
    /* Seletor de grupo de endpoints (definições OpenAPI) trazido pra dentro do header. */
    .mf-header .mf-def-select {
      margin-left: 24px;
      background: #0c2f42;
      color: #e3e1df;
      border: 1px solid rgba(227, 225, 223, 0.4);
      border-radius: 8px;
      padding: 6px 12px;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 13px;
      cursor: pointer;
    }
    .mf-header .mf-def-select:focus { outline: none; border-color: #88a15e; }

    /* Esconde a topbar padrão do swagger-ui (barra de URL do spec) — usamos o header acima. */
    .swagger-ui .topbar { display: none; }
    /* Colapsa a faixa branca do scheme-container (Servers saiu, Authorize foi pra navbar).
       Não usamos display:none porque o modal de autorização é filho daqui e é position:fixed —
       height:0 + overflow:hidden some com a faixa e com o botão, mas o modal ainda aparece. */
    .swagger-ui .scheme-container {
      height: 0;
      padding: 0;
      margin: 0;
      overflow: hidden;
      box-shadow: none;
      background: transparent;
    }

    /* Botões e acentos na paleta da marca */
    .swagger-ui .btn.authorize { color: #88a15e; border-color: #88a15e; }
    .swagger-ui .btn.authorize svg { fill: #88a15e; }
    .swagger-ui .btn.execute { background-color: #052131; border-color: #052131; }
    .swagger-ui .info .title { color: #052131; }
    .swagger-ui .info a, .swagger-ui .scheme-container .link { color: #88a15e; }

    /* Código na doc: o swagger-ui usa roxo por padrão — troca pela paleta da marca. */
    .swagger-ui .markdown code,
    .swagger-ui .renderedMarkdown code,
    .swagger-ui .info code {
      color: #052131;
      background: rgba(5, 33, 49, 0.08);
      font-family: monospace;
    }

    /* Faixa de versão do build (git) no topo da doc. */
    .mf-version {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      background: #d7d4d0;
      color: #5b686e;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 12px;
      padding: 7px 22px;
      border-bottom: 1px solid #aaa69f;
    }
    .mf-version .mf-version-branch {
      background: #88a15e;
      color: #fff;
      font-weight: bold;
      border-radius: 6px;
      padding: 2px 9px;
      text-transform: lowercase;
    }
    .mf-version code {
      color: #052131;
      background: rgba(5, 33, 49, 0.08);
      border-radius: 4px;
      padding: 1px 5px;
      font-family: monospace;
    }

    #swagger-token-banner {
      display: none;
      position: fixed;
      top: 12px;
      right: 16px;
      z-index: 9999;
      background: #88a15e;
      color: #fff;
      font-family: sans-serif;
      font-size: 13px;
      padding: 8px 14px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(5,33,49,0.2);
    }
  </style>
</head>
<body>

<header class="mf-header">
  <img src="/api-docs/logo-icon" alt="My Finance">
  <span class="mf-header-title">API Docs</span>
  <% urls = config_object[:urls] || [] %>
  <% if urls.length > 1 %>
    <select class="mf-def-select" id="mf-def-select" aria-label="Grupo de endpoints">
      <% urls.each do |u| %>
        <option value="<%= u[:url] %>"><%= u[:name] %></option>
      <% end %>
    </select>
  <% end %>
  <span class="mf-header-actions">
    <button type="button" class="mf-authorize" id="mf-authorize">
      <svg><use href="#unlocked" xlink:href="#unlocked" /></svg>
      Authorize
    </button>
    <a class="mf-logout" href="/api-docs/logout">Sair</a>
  </span>
</header>

<% __version = VersionInfo.to_h %>
<div class="mf-version">
  <span class="mf-version-branch"><%= __version[:branch] %></span>
  <span class="mf-version-item">commit <code><%= __version[:hash] %></code></span>
  <span class="mf-version-item"><%= __version[:date] %></span>
</div>

<div id="swagger-token-banner">Token aplicado automaticamente</div>

<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="position:absolute;width:0;height:0">
  <defs>
    <symbol viewBox="0 0 20 20" id="unlocked">
      <path d="M15.8 8H14V5.6C14 2.703 12.665 1 10 1 7.334 1 6 2.703 6 5.6V6h2v-.801C8 3.754 8.797 3 10 3c1.203 0 2 .754 2 2.199V8H4c-.553 0-1 .646-1 1.199V17c0 .549.428 1.139.951 1.307l1.197.387C5.672 18.861 6.55 19 7.1 19h5.8c.549 0 1.428-.139 1.951-.307l1.196-.387c.524-.167.953-.757.953-1.306V9.199C17 8.646 16.352 8 15.8 8z"></path>
    </symbol>
    <symbol viewBox="0 0 20 20" id="locked">
      <path d="M15.8 8H14V5.6C14 2.703 12.665 1 10 1 7.334 1 6 2.703 6 5.6V8H4c-.553 0-1 .646-1 1.199V17c0 .549.428 1.139.951 1.307l1.197.387C5.672 18.861 6.55 19 7.1 19h5.8c.549 0 1.428-.139 1.951-.307l1.196-.387c.524-.167.953-.757.953-1.306V9.199C17 8.646 16.352 8 15.8 8zM12 8H8V5.199C8 3.754 8.797 3 10 3c1.203 0 2 .754 2 2.199V8z"/>
    </symbol>
    <symbol viewBox="0 0 20 20" id="close">
      <path d="M14.348 14.849c-.469.469-1.229.469-1.697 0L10 11.819l-2.651 3.029c-.469.469-1.229.469-1.697 0-.469-.469-.469-1.229 0-1.697l2.758-3.15-2.759-3.152c-.469-.469-.469-1.228 0-1.697.469-.469 1.228-.469 1.697 0L10 8.183l2.651-3.031c.469-.469 1.228-.469 1.697 0 .469.469.469 1.229 0 1.697l-2.758 3.152 2.758 3.15c.469.469.469 1.229 0 1.698z"/>
    </symbol>
    <symbol viewBox="0 0 20 20" id="large-arrow">
      <path d="M13.25 10L6.109 2.58c-.268-.27-.268-.707 0-.979.268-.27.701-.27.969 0l7.83 7.908c.268.271.268.709 0 .979l-7.83 7.908c-.268.271-.701.27-.969 0-.268-.269-.268-.707 0-.979L13.25 10z"/>
    </symbol>
    <symbol viewBox="0 0 20 20" id="large-arrow-down">
      <path d="M17.418 6.109c.272-.268.709-.268.979 0s.271.701 0 .969l-7.908 7.83c-.27.268-.707.268-.979 0l-7.908-7.83c-.27-.268-.27-.701 0-.969.271-.268.709-.268.979 0L10 13.25l7.418-7.141z"/>
    </symbol>
    <symbol viewBox="0 0 24 24" id="jump-to">
      <path d="M19 7v4H5.83l3.58-3.59L8 6l-6 6 6 6 1.41-1.41L5.83 13H21V7z"/>
    </symbol>
    <symbol viewBox="0 0 24 24" id="expand">
      <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"/>
    </symbol>
  </defs>
</svg>

<div id="swagger-ui"></div>

<script>
  if (window.navigator.userAgent.indexOf("Edge") > -1) {
    console.log("Removing native Edge fetch in favor of swagger-ui's polyfill")
    window.fetch = undefined;
  }
</script>

<script src="./swagger-ui-bundle.js"></script>
<script src="./swagger-ui-standalone-preset.js"></script>
<script>
  window.onload = function () {
    var configObject = JSON.parse('<%= config_object.to_json %>');
    var oauthConfigObject = JSON.parse('<%= oauth_config_object.to_json %>');

    configObject.dom_id = "#swagger-ui";
    configObject.presets = [SwaggerUIBundle.presets.apis, SwaggerUIStandalonePreset];
    configObject.layout = "StandaloneLayout";
    configObject.persistAuthorization = true;

    if (!configObject.hasOwnProperty("oauth2RedirectUrl"))
      configObject.oauth2RedirectUrl = window.location.href.replace("index.html", "oauth2-redirect.html");

    var _ui;

    configObject.responseInterceptor = function (response) {
      try {
        // response.obj é o JSON já parseado pelo Swagger UI; response.body é fallback string
        var body = response.obj;
        if (!body && typeof response.body === 'string') body = JSON.parse(response.body);
        var token = body && body.data && body.data.token;
        if (token && _ui) {
          var authEntry = {
            bearerAuth: {
              name: 'bearerAuth',
              schema: { type: 'http', scheme: 'bearer', bearerFormat: 'JWT' },
              value: token
            }
          };
          _ui.getSystem().authActions.authorize(authEntry);
          // Garante persistência — authActions.authorize() direto pode não acionar
          // o hook do persistAuthorization, então salvamos explicitamente fazendo
          // merge com o que já está salvo para não apagar outros tokens (ex: apiKeyAuth)
          try {
            var existing = JSON.parse(localStorage.getItem('authorized') || '{}');
            localStorage.setItem('authorized', JSON.stringify(Object.assign(existing, authEntry)));
          } catch (e) {}
          var banner = document.getElementById('swagger-token-banner');
          banner.style.display = 'block';
          setTimeout(function () { banner.style.display = 'none'; }, 3000);
        }
      } catch (e) { console.warn('[swagger] responseInterceptor error', e); }
      return response;
    };

    const ui = SwaggerUIBundle(configObject);
    _ui = ui;

    ui.initOAuth(oauthConfigObject);

    // Troca de grupo de endpoints (definição OpenAPI) pelo select do header.
    var defSelect = document.getElementById('mf-def-select');
    if (defSelect) {
      defSelect.addEventListener('change', function () {
        ui.specActions.updateUrl(this.value);
        ui.specActions.download(this.value);
      });
    }

    // Botão Authorize do header: aciona o botão real (escondido) que abre o modal do swagger-ui.
    var authBtn = document.getElementById('mf-authorize');
    if (authBtn) {
      authBtn.addEventListener('click', function () {
        var real = document.querySelector('.swagger-ui .btn.authorize');
        if (real) real.click();
      });
    }
  }
</script>
</body>
</html>
