<!-- HTML for static distribution bundle build -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Finance API Docs</title>
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,700|Source+Code+Pro:300,600|Titillium+Web:400,600,700" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="./swagger-ui.css" >
  <link rel="icon" type="image/png" href="./favicon-32x32.png" sizes="32x32" />
  <link rel="icon" type="image/png" href="./favicon-16x16.png" sizes="16x16" />
  <style>
    html {
      box-sizing: border-box;
      overflow: -moz-scrollbars-vertical;
      overflow-y: scroll;
    }
    *,
    *:before,
    *:after {
      box-sizing: inherit;
    }
    body {
      margin: 0;
      background: #fafafa;
    }
    #swagger-token-banner {
      display: none;
      position: fixed;
      top: 12px;
      right: 16px;
      z-index: 9999;
      background: #49cc90;
      color: #fff;
      font-family: sans-serif;
      font-size: 13px;
      padding: 8px 14px;
      border-radius: 4px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
  </style>
</head>
<body>

<div id="swagger-token-banner">Token aplicado automaticamente</div>

<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" style="position:absolute;width:0;height:0">
  <defs>
    <symbol viewBox="0 0 20 20" id="unlocked">
      <path d="M15.8 8H14V5.6C14 2.703 12.665 1 10 1 7.334 1 6 2.703 6 5.6V6h2v-.801C8 3.754 8.797 3 10 3c1.203 0 2 .754 2 2.199V8H4c-.553 0-1 .646-1 1.199V17c0 .549.428 1.139.951 1.307l1.197.387C5.672 18.861 6.55 19 7.1 19h5.8c.549 0 1.428-.139 1.951-.307l1.196-.387c.524-.167.953-.757.953-1.306V9.199C17 8.646 16.352 8 15.8 8z"></path>
    </symbol>
    <symbol viewBox="0 0 20 20" id="locked">
      <path d="M15.8 8H14V5.6C14 2.703 12.665 1 10 1 7.334 1 6 2.703 6 5.6V8H4c-.553 0-1 .646-1 1.199V17c0 .549.428 1.139.951 1.307l1.197.387C5.672 18.861 6.55 19 7.1 19h5.8c.549 0 1.428-.139 1.951-.307l1.196-.387c.524-.167.953-.757.953-1.306V9.199C17 8.646 16.352 8 15.8 8zM12 8H8V5.199C8 3.754 8.797 3 10 3c1.203 0 2 .754 2 2.199V8z"/>
    </symbol>
    <symbol viewBox="0 0 20 20" id="close">
      <path d="M14.348 14.849c-.469.469-1.229.469-1.697 0L10 11.819l-2.651 3.029c-.469.469-1.229.469-1.697 0-.469-.469-.469-1.229 0-1.697l2.758-3.15-2.759-3.152c-.469-.469-.469-1.228 0-1.697.469-.469 1.228-.469 1.697 0L10 8.183l2.651-3.031c.469-.469 1.228-.469 1.697 0 .469.469.469 1.229 0 1.697l-2.758 3.152 2.758 3.15c.469.469.469 1.229 0 1.698z"/>
    </symbol>
    <symbol viewBox="0 0 20 20" id="large-arrow">
      <path d="M13.25 10L6.109 2.58c-.268-.27-.268-.707 0-.979.268-.27.701-.27.969 0l7.83 7.908c.268.271.268.709 0 .979l-7.83 7.908c-.268.271-.701.27-.969 0-.268-.269-.268-.707 0-.979L13.25 10z"/>
    </symbol>
    <symbol viewBox="0 0 20 20" id="large-arrow-down">
      <path d="M17.418 6.109c.272-.268.709-.268.979 0s.271.701 0 .969l-7.908 7.83c-.27.268-.707.268-.979 0l-7.908-7.83c-.27-.268-.27-.701 0-.969.271-.268.709-.268.979 0L10 13.25l7.418-7.141z"/>
    </symbol>
    <symbol viewBox="0 0 24 24" id="jump-to">
      <path d="M19 7v4H5.83l3.58-3.59L8 6l-6 6 6 6 1.41-1.41L5.83 13H21V7z"/>
    </symbol>
    <symbol viewBox="0 0 24 24" id="expand">
      <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"/>
    </symbol>
  </defs>
</svg>

<div id="swagger-ui"></div>

<script>
  if (window.navigator.userAgent.indexOf("Edge") > -1) {
    console.log("Removing native Edge fetch in favor of swagger-ui's polyfill")
    window.fetch = undefined;
  }
</script>

<script src="./swagger-ui-bundle.js"></script>
<script src="./swagger-ui-standalone-preset.js"></script>
<script>
  window.onload = function () {
    var configObject = JSON.parse('<%= config_object.to_json %>');
    var oauthConfigObject = JSON.parse('<%= oauth_config_object.to_json %>');

    configObject.dom_id = "#swagger-ui";
    configObject.presets = [SwaggerUIBundle.presets.apis, SwaggerUIStandalonePreset];
    configObject.layout = "StandaloneLayout";
    configObject.persistAuthorization = true;

    if (!configObject.hasOwnProperty("oauth2RedirectUrl"))
      configObject.oauth2RedirectUrl = window.location.href.replace("index.html", "oauth2-redirect.html");

    var _ui;

    configObject.responseInterceptor = function (response) {
      try {
        // response.obj é o JSON já parseado pelo Swagger UI; response.body é fallback string
        var body = response.obj;
        if (!body && typeof response.body === 'string') body = JSON.parse(response.body);
        var token = body && body.data && body.data.token;
        if (token && _ui) {
          var authEntry = {
            bearerAuth: {
              name: 'bearerAuth',
              schema: { type: 'http', scheme: 'bearer', bearerFormat: 'JWT' },
              value: token
            }
          };
          _ui.getSystem().authActions.authorize(authEntry);
          // Garante persistência — authActions.authorize() direto pode não acionar
          // o hook do persistAuthorization, então salvamos explicitamente fazendo
          // merge com o que já está salvo para não apagar outros tokens (ex: apiKeyAuth)
          try {
            var existing = JSON.parse(localStorage.getItem('authorized') || '{}');
            localStorage.setItem('authorized', JSON.stringify(Object.assign(existing, authEntry)));
          } catch (e) {}
          var banner = document.getElementById('swagger-token-banner');
          banner.style.display = 'block';
          setTimeout(function () { banner.style.display = 'none'; }, 3000);
        }
      } catch (e) { console.warn('[swagger] responseInterceptor error', e); }
      return response;
    };

    const ui = SwaggerUIBundle(configObject);
    _ui = ui;

    ui.initOAuth(oauthConfigObject);

    (function persistServer() {
      var SELECT_KEY = 'swagger_selected_server';
      var VARS_KEY   = 'swagger_server_vars';

      var nativeSetter = Object.getOwnPropertyDescriptor(HTMLSelectElement.prototype, 'value').set;
      var nativeInputSetter = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, 'value').set;

      function saveServer(url) {
        try { localStorage.setItem(SELECT_KEY, url); } catch (e) {}
      }

      function getSavedServer() {
        try { return localStorage.getItem(SELECT_KEY); } catch (e) { return null; }
      }

      function saveVars(vars) {
        try { localStorage.setItem(VARS_KEY, JSON.stringify(vars)); } catch (e) {}
      }

      function getSavedVars() {
        try { return JSON.parse(localStorage.getItem(VARS_KEY) || '{}'); } catch (e) { return {}; }
      }

      function attachVarInputs() {
        var inputs = document.querySelectorAll('input[data-variable]');
        inputs.forEach(function (input) {
          if (input._varPersistAttached) return;
          input._varPersistAttached = true;

          // Restaura valor salvo
          var saved = getSavedVars()[input.dataset.variable];
          if (saved) {
            nativeInputSetter.call(input, saved);
            input.dispatchEvent(new Event('input', { bubbles: true }));
            input.dispatchEvent(new Event('change', { bubbles: true }));
          }

          // Salva ao digitar
          input.addEventListener('input', function () {
            var vars = getSavedVars();
            vars[this.dataset.variable] = this.value;
            saveVars(vars);
          });
        });
      }

      var observer = new MutationObserver(function () {
        var select = document.querySelector('.servers select');
        if (select && !select._serverPersistAttached) {
          select._serverPersistAttached = true;

          var saved = getSavedServer();
          if (saved) {
            for (var i = 0; i < select.options.length; i++) {
              if (select.options[i].value === saved) {
                nativeSetter.call(select, saved);
                select.dispatchEvent(new Event('change', { bubbles: true }));
                break;
              }
            }
          }

          select.addEventListener('change', function () {
            saveServer(this.value);
          });
        }

        // Verifica se apareceu algum input de variável (ex: baseUrl)
        attachVarInputs();
      });

      observer.observe(document.getElementById('swagger-ui'), {
        childList: true,
        subtree: true
      });
    })();
  }
</script>
</body>
</html>
