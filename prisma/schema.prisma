generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TransactionKind {
  deposit
  withdraw
}

model Transaction {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  description      String
  value            Int
  kind             TransactionKind
  wallet_id        String    @db.ObjectId
  wallet           Wallet    @relation(fields: [wallet_id], references: [id])
  transaction_date DateTime
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  discarded_at     DateTime?

  @@map("transactions")
}

model Wallet {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  transactions Transaction[]
  user_wallets UserWallet[]
  owner_id     String        @db.ObjectId
  owner        User          @relation(fields: [owner_id], references: [id])
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  discarded_at DateTime?

  @@map("wallets")
}

model UserWallet {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id           String    @db.ObjectId
  user              User      @relation("user_wallets", fields: [user_id], references: [id])
  wallet_id         String    @db.ObjectId
  wallet            Wallet    @relation(fields: [wallet_id], references: [id])
  users_main_wallet User[]    @relation("main_user_wallet")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  discarded_at      DateTime?

  @@map("user_wallets")
}

model User {
  id                  String       @id @default(auto()) @map("_id") @db.ObjectId
  email               String       @unique
  name                String
  password            String
  main_user_wallet_id String?      @db.ObjectId
  main_user_wallet    UserWallet?  @relation("main_user_wallet", fields: [main_user_wallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_wallets        UserWallet[] @relation("user_wallets")
  my_wallets          Wallet[]
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt
  discarded_at        DateTime?

  @@map("users")
}
